  "types": [
    {
      "name": "Auction",
      "docs": [
        "State stored on-chain (L1 before/after delegation, PER during active bidding).",
        "While delegated to the Private Ephemeral Rollup (TEE), only `bid_count` and",
        "`status` are visible in real-time via the ER connection. Bid amounts live",
        "in private `Bid` PDAs, accessible only to each bidder via the Permission",
        "Program's access-control groups."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "seller",
            "docs": [
              "Seller's wallet — only they can close + settle"
            ],
            "type": "pubkey"
          },
          {
            "name": "title",
            "docs": [
              "Human-readable title shown in the UI"
            ],
            "type": "string"
          },
          {
            "name": "reserve_price",
            "docs": [
              "Minimum winning bid (in lamports)"
            ],
            "type": "u64"
          },
          {
            "name": "start_time",
            "docs": [
              "Unix timestamp: auction start"
            ],
            "type": "i64"
          },
          {
            "name": "end_time",
            "docs": [
              "Unix timestamp: bidding deadline"
            ],
            "type": "i64"
          },
          {
            "name": "bid_count",
            "docs": [
              "Number of bids placed so far (public, real-time visible on PER)"
            ],
            "type": "u32"
          },
          {
            "name": "status",
            "docs": [
              "State machine: Created → Delegated → Closed → Settled"
            ],
            "type": {
              "defined": {
                "name": "AuctionStatus"
              }
            }
          },
          {
            "name": "winner",
            "docs": [
              "Populated by close_auction running inside TEE"
            ],
            "type": "pubkey"
          },
          {
            "name": "winning_bid",
            "docs": [
              "Winning amount in lamports (revealed after TEE computation)"
            ],
            "type": "u64"
          },
          {
            "name": "auction_id",
            "docs": [
              "Unique auction ID used in PDA derivation"
            ],
            "type": "u64"
          },
          {
            "name": "nft_mint",
            "docs": [
              "Mint of the escrowed token/NFT"
            ],
            "type": "pubkey"
          },
          {
            "name": "escrow_amount",
            "docs": [
              "Amount of tokens escrowed (1 for NFT, any for fungible tokens)"
            ],
            "type": "u64"
          },
          {
            "name": "settle_deadline",
            "docs": [
              "Unix timestamp deadline for winner to settle (set by close_auction)",
              "If winner doesn't pay by this time, seller can cancel and reclaim tokens."
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed"
            ],
            "type": "u8"
          },
          {
            "name": "bidders",
            "docs": [
              "Public list of *who* bid (not amounts). Allows close_auction to derive",
              "each Bid PDA without storing amounts in the auction state."
            ],
            "type": {
              "vec": "pubkey"
            }
          }
        ]
      }
    },
    {
      "name": "AuctionClosed",
      "docs": [
        "Emitted on L1 as part of the TEE commit transaction.",
        "This event is the public, verifiable proof of the TEE computation result."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "auction",
            "type": "pubkey"
          },
          {
            "name": "winner",
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "winning_bid",
            "type": "u64"
          },
          {
            "name": "bid_count",
            "type": "u32"
          },
          {
            "name": "success",
            "type": "bool"
          }
        ]
      }
    },
    {
      "name": "AuctionCreated",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "auction",
            "type": "pubkey"
          },
          {
            "name": "seller",
            "type": "pubkey"
          },
          {
            "name": "auction_id",
            "type": "u64"
          },
          {
            "name": "reserve_price",
            "type": "u64"
          },
          {
            "name": "end_time",
            "type": "i64"
          },
          {
            "name": "title",
            "type": "string"
          },
          {
            "name": "nft_mint",
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "AuctionSettled",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "auction",
            "type": "pubkey"
          },
          {
            "name": "winner",
            "type": "pubkey"
          },
          {
            "name": "seller",
            "type": "pubkey"
          },
          {
            "name": "winning_bid",
            "type": "u64"
          }
        ]
      }
    },
    {
      "name": "AuctionStatus",
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Created"
          },
          {
            "name": "Delegated"
          },
          {
            "name": "Closed"
          },
          {
            "name": "Settled"
          },
          {
            "name": "Cancelled"
          }
        ]
      }
    },
    {
      "name": "Bid",
      "docs": [
        "Private bid account. Lives on the Private Ephemeral Rollup (TEE).",
        "The Permission Program restricts RPC read access to this PDA so that only",
        "the bidder can query their own amount. The TEE can read all bids during",
        "winner computation (close_auction instruction)."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "auction",
            "docs": [
              "Parent auction"
            ],
            "type": "pubkey"
          },
          {
            "name": "bidder",
            "docs": [
              "The bidder's wallet"
            ],
            "type": "pubkey"
          },
          {
            "name": "amount",
            "docs": [
              "Bid amount in lamports — PRIVATE (permission-gated via PER middleware)"
            ],
            "type": "u64"
          },
          {
            "name": "timestamp",
            "docs": [
              "When the bid was placed"
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed"
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "BidPermissionCreated",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "auction",
            "type": "pubkey"
          },
          {
            "name": "bidder",
            "type": "pubkey"
          },
          {
            "name": "bid_pda",
            "type": "pubkey"
          },
          {
            "name": "permission_group",
            "type": "pubkey"
          }
        ]
      }
    },
    {
      "name": "BidPlaced",
      "docs": [
        "Public event emitted per bid — NO amount included.",
        "Subscribers to the PER WebSocket see this in real-time, confirming",
        "\"a sealed bid was received\" without revealing anything about the amount."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "auction",
            "type": "pubkey"
          },
          {
            "name": "bidder",
            "type": "pubkey"
          },
          {
            "name": "bid_count",
            "type": "u32"
          },
          {
            "name": "timestamp",
            "type": "i64"
          }
        ]
      }
    }
